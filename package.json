{
  "name": "are-we-there-yet",
  "displayName": "are-we-there-yet",
  "icon":"images/icon.png",
  "description": "get notified when the task is complete",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url":"https://github.com/Pobitro-B/are-we-there-yet.git"
    },
  "homepage": "https://github.com/Pobitro-B/are-we-there-yet",
  "bugs": {
    "url": "https://github.com/Pobitro-B/are-we-there-yet/issues"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": ["onStartupFinished","onTerminal"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "are-we-there-yet.testNotification",
        "title": "Are We There Yet: Send Test Notification"
      },
      {
        "command": "are-we-there-yet.openSettings",
        "title": "Are We There Yet: Open Settings"
      }
    ],
    "configuration": {
      "title": "Are We There Yet",
      "properties": {
        "areWeThereYet.botToken": {
          "type": "string",
          "default": "",
          "description": "Telegram bot token"
        },
        "areWeThereYet.chatId": {
          "type": "string",
          "default": "",
          "description": "Telegram chat ID"
        },
        "areWeThereYet.minimumDurationSeconds": {
          "type": "number",
          "default": 30,
          "description": "Minimum command duration before sending a notification"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
